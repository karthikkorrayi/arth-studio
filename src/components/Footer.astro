---
const currentYear = new Date().getFullYear();
const social = [
  { label: 'Instagram', href: 'https://www.instagram.com/arth.studio_/' },
  // { label: 'Pinterest', href: 'https://pinterest.com/arth' },
  // { label: 'LinkedIn', href: 'https://linkedin.com/company/arth-studio' },
];
---

<footer class="border-t border-line">
  <div class="mx-auto flex max-w-7xl flex-col gap-6 px-6 py-10 sm:flex-row sm:items-center sm:justify-between lg:px-10">
    <p class="font-mono text-xs uppercase tracking-widest2 text-ink-soft">
      © {currentYear} ARTH STUDIO. All rights reserved.
    </p>

    <ul class="flex items-center gap-8">
      {social.map((item) => (
        <li>
          <a
            href={item.href}
            target="_blank"
            rel="noreferrer noopener"
            class="font-mono text-xs uppercase tracking-widest2 text-ink-soft transition-colors duration-300 ease-studio hover:text-ink"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</footer>
